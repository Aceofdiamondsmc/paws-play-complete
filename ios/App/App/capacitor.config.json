{
	"appId": "com.pawsplayrepeat.app",
	"appName": "Paws Play Repeat",
	"webDir": "dist",
	"server": {
		"iosScheme": "com.pawsplayrepeat.app",
		"androidScheme": "https"
	},
	"plugins": {
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		},
		"Keyboard": {
			"resize": "none",
			"style": "DEFAULT",
			"resizeOnFullScreen": false
		}
	},
	"packageClassList": [
		"AppPlugin",
		"CAPBrowserPlugin",
		"FilesystemPlugin",
		"KeyboardPlugin",
		"LocalNotificationsPlugin",
		"PushNotificationsPlugin",
		"SharePlugin",
		"PurchasesPlugin"
	]
}
